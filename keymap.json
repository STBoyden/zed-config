// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "j z z"],
      "k": ["workspace::SendKeystrokes", "k z z"],
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "j z z"],
      "k": ["workspace::SendKeystrokes", "k z z"],
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
      "bindings": {
      "ctrl-alt-cmd-}": "multi_workspace::NextProject"
    }
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "unbind": {
      "] p": "multi_workspace::NextProject"
    }
  },
  {
    "context": "Workspace",
      "bindings": {
      "ctrl-alt-cmd-{": "multi_workspace::PreviousProject"
    }
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "unbind": {
      "[ p": "multi_workspace::PreviousProject"
    }
  },
  {
    "bindings": {
      "alt-t": "terminal_panel::ToggleFocus"
    }
  }
]
