// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "(CommitEditor || MessageEditor) > vim_mode == normal || vim_mode == visual",
    "bindings": {
      "k": ["workspace::SendKeystrokes", "g k"],
    },
  },
  {
    "context": "!AcpThread && Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "k": ["workspace::SendKeystrokes", "k z z"],
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-cmd-}": "multi_workspace::NextProject",
    },
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "unbind": {
      "] p": "multi_workspace::NextProject",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-cmd-{": "multi_workspace::PreviousProject",
    },
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "unbind": {
      "[ p": "multi_workspace::PreviousProject",
    },
  },
  {
    "bindings": {
      "alt-t": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-]": "editor::Indent",
    },
  },
  {
    "bindings": {
      "cmd-}": "panel::NextPanelTab",
    },
  },
  {
    "bindings": {
      "cmd-{": "panel::PreviousPanelTab",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-[": "editor::Outdent",
    },
  },
  {
    "context": "(CommitEditor || MessageEditor) > vim_mode == normal || vim_mode == visual",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "g j"],
    },
  },
  {
    "context": "!AcpThread && Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "j z z"],
    },
  },
  {
    "context": "(vim_mode == normal || vim_mode == visual) && !menu",
    "bindings": {
      ", ,": "vim::HelixJumpToWord",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "g w": "vim::HelixJumpToWord",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j j": "vim::SwitchToNormalMode",
      "j k": "vim::SwitchToNormalMode",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "alt-shift-m": "vim::ToggleMarksView"
    }
  }
]
