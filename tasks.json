// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
//
// Example:
[
  {
    "label": "LazyGit",
    "command": "lazygit",
    "shell": {
      "program": "sh",
    },
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
  },
  {
    "label": "Zed Config: Install script dependencies",
    "command": "nu ./scripts/install-dependencies.nu",
    "cwd": "~/.config/zed",
    "show_command": false,
    "show_summary": false,
    "hide": "on_success",
  },
  {
    "label": "Zed Config: Open config directory",
    "command": "nu ./scripts/open-zed-settings.nu",
    "cwd": "~/.config/zed",
    "show_command": false,
    "show_summary": false,
    "hide": "on_success",
  },
  {
    "label": "Zed Config: Open config directory in Zed",
    "command": "nu ./scripts/open-zed-config.nu",
    "cwd": "~/.config/zed",
    "show_command": false,
    "show_summary": false,
    "hide": "on_success",
  },
  {
    "label": "Zed Config: Check for update",
    "command": "nu ./scripts/check-remote.nu",
    "cwd": "~/.config/zed",
    "reveal_target": "center",
    "allow_concurrent_runs": false,
    "use_new_terminal": true,
  },
  {
    "label": "Zed Config: Update local from remote",
    "command": "nu ./scripts/update-local.nu",
    "cwd": "~/.config/zed",
    "hide": "on_success",
    "reveal_target": "center",
    "allow_concurrent_runs": false,
    "use_new_terminal": true,
  },
  {
    "label": "Zed Config: Update remote from local",
    "command": "nu ./scripts/update-remote.nu",
    "cwd": "~/.config/zed",
    "hide": "on_success",
    "reveal_target": "center",
    "allow_concurrent_runs": false,
    "use_new_terminal": true,
  },
  {
    "label": "Zed Config: Update or clone journal",
    "command": "nu ./scripts/clone-journal.nu",
    "cwd": "~/.config/zed",
    "use_new_terminal": true,
    "reveal": "no_focus",
    "allow_concurrent_runs": false,
    "hide": "on_success",
  },
  {
    "label": "New Worktree: Copy env files from main worktree",
    "command": "nu",
    "args": ["~/.config/zed/scripts/copy-env-files-to-worktree.nu"],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
  {
    "label": "New Worktree: Create branch for worktree",
    "command": "nu",
    "args": ["~/.config/zed/scripts/create-branch-for-worktree.nu"],
    "hooks": ["create_worktree"],
    "reveal": "no_focus",
    "hide": "on_success",
  },
  {
    "label": "Branch off from $ZED_GIT_SHA_SHORT",
    "command": "git",
    "args": ["checkout", "-b", "branch-$ZED_GIT_SHA_SHORT", "$ZED_GIT_SHA"],
    "tags": ["git-command"],
    "hide": "on_success",
    "reveal": "no_focus",
  },
  {
    "label": "Reset hard to commit: $ZED_GIT_SHA_SHORT",
    "command": "git",
    "args": ["reset", "--hard", "$ZED_GIT_SHA"],
    "tags": ["git-command"],
    "hide": "on_success",
    "reveal": "no_focus",
  },
  {
    "label": "Reset mixed to commit: $ZED_GIT_SHA_SHORT",
    "command": "git",
    "args": ["reset", "--mixed", "$ZED_GIT_SHA"],
    "tags": ["git-command"],
    "hide": "on_success",
    "reveal": "no_focus",
  },
  {
    "label": "Reset soft to commit: $ZED_GIT_SHA_SHORT",
    "command": "git",
    "args": ["reset", "--soft", "$ZED_GIT_SHA"],
    "tags": ["git-command"],
    "hide": "on_success",
    "reveal": "no_focus",
  },
]
