// Zed settings
//
// For information on how to configure Zed, see the Zed documentation:
// https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your custom settings,
// run `zed: open default settings` from the command palette (cmd-shift-p /
// ctrl-shift-p)
{
  "gutter": {},
  "minimap": {
    "show": "always",
    "max_width_columns": 80,
    "display_in": "active_editor",
    "thumb": "always",
  },
  "show_completion_documentation": false,
  "show_completions_on_input": false,
  "hover_popover_enabled": false,
  "hover_popover_delay": 300,
  "document_symbols": "on",
  "buffer_font_weight": 500.0,
  "git_panel": {
    "dock": "right",
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["plan", "dontAsk"],
      },
      "type": "registry",
    },
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "text_rendering_mode": "platform_default",
  "which_key": {
    "enabled": true,
  },
  "disable_ai": false,
  "document_folding_ranges": "on",
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [".env.*", "!.env.example"],
  },
  "enable_language_server": true,
  "use_system_path_prompts": true,
  "use_system_prompts": true,
  "preferred_line_length": 100,
  "soft_wrap": "none",
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": false,
  },
  "show_whitespaces": "all",
  "whitespace_map": {
    "tab": ">",
  },
  "tab_size": 2,
  "prettier": {
    "allowed": true,
  },
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "tabs": {
    "close_position": "left",
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_menus": true,
  },
  "confirm_quit": true,
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-5",
    },
    "dock": "right",
    "button": true,
    "enabled": true,
  },
  "icon_theme": {
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
    "mode": "system",
  },
  "outline_panel": {
    "dock": "left",
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": true,
  },
  "centered_layout": {
    "left_padding": 0.05,
    "right_padding": 0.05,
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "auto_reveal_entries": true,
    "folder_icons": true,
    "file_icons": true,
    "hide_gitignore": false,
    "indent_size": 20.0,
    "entry_spacing": "comfortable",
    "hide_root": true,
    "sticky_scroll": false,
    "dock": "right",
  },
  "theme_overrides": {
    "Ayu Dark": {
      "vim.mode.text": "#294d64",
      "vim.normal.background": "#39bae6",
      "vim.insert.background": "#aad94C",
      "vim.visual.background": "#ff8f40",
      "vim.replace.background": "#ed8796",
      "vim.visual_line.background": "#ffb454",
      "vim.visual_block.background": "#e6b673",
      "vim.helix_select.background": "#b3blad",
      "vim.helix_normal.background": "#59c2ff",
    },
  },
  "use_autoclose": true,
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "buffer_font_family": "IoskeleyMono Nerd Font",
  "buffer_line_height": "standard",
  "ui_font_family": ".ZedSans",
  "ui_font_weight": 500,
  "unstable.ui_density": "comfortable",
  "restore_on_startup": "launchpad",
  "preview_tabs": {
    "enabled": true,
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "system",
  },
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": false,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
    "show_background": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": "IoskeleyMono Nerd Font",
    "font_fallbacks": ["Cascadia Code NF"],
    "font_size": 16,
    "env": {
      "EDITOR": "zed --wait",
    },
    "cursor_shape": "bar",
  },
  "scrollbar": {
    "show": "never",
  },
  "indent_guides": {
    "active_line_width": 3,
    "line_width": 2,
    "background_coloring": "disabled",
    "enabled": true,
    "coloring": "fixed",
  },
  "relative_line_numbers": "disabled",
  "wrap_guides": [100],
  "semantic_tokens": "combined",
  "show_wrap_guides": false,
  "auto_install_extensions": {
    "basher": true,
    "cargo-appraiser": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "crates-lsp": true,
    "docker-compose": true,
    "dockerfile": true,
    "git-firefly": true,
    "golangci-lint": true,
    "gosum": true,
    "html": true,
    "just": true,
    "kotlin": true,
    "log": true,
    "make": true,
    "nord": true,
    "package-swift-lsp": true,
    "prisma": true,
    "ruby": true,
    "svelte": true,
    "swift": true,
    "templ": true,
    "toml": true,
    "vscode-icons": true,
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "update_debounce_ms": 100,
      "padding": 4,
      "min_column": 0,
      "enabled": true,
    },
    "button": true,
  },
  "languages": {
    "Prisma": {
      "prettier": {
        "allowed": false,
      },
    },
    "TSX": {
      "prettier": {
        "allowed": true,
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "prettier": {
        "allowed": true,
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
        },
      },
    },
    "Svelte": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
    },
    "Templ": {
      "formatter": "language_server",
      "format_on_save": "on",
      "use_autoclose": false,
      "language_servers": ["templ", "tailwindcss-language-server"],
      "jsx_tag_auto_close": {
        "enabled": true,
      },
    },
    "Swift": {
      "hard_tabs": true,
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 24576,
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 24576,
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "templ": "html",
        },
      },
    },
    "vscode-html-language-server": {
      "settings": {
        "html": {
          "suggest": {
            "html5": true,
            "angular1": true,
            "ionic": true,
          },
          "validate": {
            "scripts": true,
            "styles": true,
          },
          "format": {
            "wrapLineLength": 120,
            "unformatted": "wbr,code,pre",
          },
          "includeLanguages": {
            "templ": "html",
            "Templ": "html",
          },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
}
