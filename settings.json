// Zed settings
//
// For information on how to configure Zed, see the Zed documentation:
// https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your custom settings,
// run `zed: open default settings` from the command palette (cmd-shift-p /
// ctrl-shift-p)
{
  "completion_menu_item_kind": "symbol",
  "semantic_tokens": "combined",
  "search": {
    "center_on_match": true,
    "include_ignored": false,
  },
  "code_lens": "on",
  "hard_tabs": false,
  "toolbar": {
    "code_actions": true,
  },
  "context_servers": {
    "Xcode": {
      "enabled": true,
      "remote": false,
      "command": "xcrun",
      "args": ["mcpbridge"],
      "env": {},
    },
  },
  "ui_font_family": ".SystemUIFont",
  "language_models": {
    "opencode": {
      "show_zen_models": false,
      "show_go_models": false,
    },
  },
  "autoscroll_on_clicks": true,
  "helix_mode": false,
  "cli_default_open_behavior": "existing_window",
  "diff_view_style": "split",
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "completion_menu_scrollbar": "auto",
  "focus_follows_mouse": {
    "enabled": false,
  },
  "snippet_sort_order": "bottom",
  "active_pane_modifiers": {
    "border_size": -1.0,
    "inactive_opacity": 1.0,
  },
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "status_bar": {
    "line_endings_button": true,
    "show_active_file": true,
    "active_encoding_button": "enabled",
  },
  "gutter": {},
  "minimap": {
    "show": "never",
    "max_width_columns": 80,
    "display_in": "active_editor",
    "thumb": "always",
  },
  "show_completion_documentation": true,
  "show_completions_on_input": true,
  "hover_popover_enabled": true,
  "hover_popover_delay": 300,
  "document_symbols": "on",
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
    "collapse_untracked_diff": false,
    "sort_by_path": true,
    "status_style": "icon",
    "dock": "left",
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "low",
        "mode": "full-access",
        "model": "gpt-5.5",
      },
      "type": "registry",
    },
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "mode": ["https://agentclientprotocol.com/protocol/session-modes#autopilot"],
      },
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions",
      },
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"],
      },
      "type": "registry",
    },
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "which_key": {
    "enabled": true,
  },
  "disable_ai": false,
  "document_folding_ranges": "on",
  "edit_predictions": {
    "mode": "eager",
    "provider": "zed",
    "disabled_globs": [".env.*", "!.env.example"],
  },
  "enable_language_server": true,
  "use_system_path_prompts": true,
  "use_system_prompts": true,
  "preferred_line_length": 100,
  "soft_wrap": "none",
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": false,
  },
  "show_whitespaces": "all",
  "whitespace_map": {
    "tab": ">",
  },
  "tab_size": 2,
  "prettier": {
    "allowed": true,
  },
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "tabs": {
    "show_close_button": "hover",
    "close_position": "left",
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "button_layout": "platform_default",
    "show_menus": true,
  },
  "confirm_quit": true,
  "agent": {
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "free/minimax-m2.5-free",
      },
    ],
    "show_turn_stats": true,
    "thinking_display": "preview",
    "use_modifier_to_send": true,
    "notify_when_agent_waiting": "all_screens",
    "play_sound_when_agent_done": "when_hidden",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "provider": "opencode",
      "model": "free/minimax-m2.5-free",
    },
    "commit_message_model": {
      "provider": "opencode",
      "model": "free/minimax-m2.5-free",
    },
    "dock": "left",
    "button": true,
    "enabled": true,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "outline_panel": {
    "dock": "left",
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show": true,
    "show_nav_history_buttons": true,
  },
  "centered_layout": {
    "left_padding": 0.05,
    "right_padding": 0.05,
  },
  "project_panel": {
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "scrollbar": {
      "show": "auto",
      "horizontal_scroll": true,
    },
    "bold_folder_labels": false,
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "folder_icons": true,
    "file_icons": true,
    "hide_gitignore": false,
    "indent_size": 20.0,
    "entry_spacing": "standard",
    "hide_root": true,
    "sticky_scroll": false,
    "dock": "right",
  },
  "use_autoclose": true,
  "ui_font_size": 15.0,
  "buffer_font_size": 15.0,
  "buffer_font_family": "Monaspace Krypton NF",
  "buffer_line_height": "standard",
  "buffer_font_features": {
    "calt": true, // texture healing
    "liga": true, // // /// //// || ||| ||||
    "ss01": true, // != ===
    "ss02": true, // <= >=
    "ss03": true, // ~> ->
    "ss04": true, // </ /> </>
    "ss05": true, // |> <| <|>
    "ss06": true, // ## ++ __ == &&
    "ss07": true, // :: =:=
    "ss08": true, // ..= .-
    "ss09": true, // <=> >> =<<
    "ss10": true, // #[ ]# #( )#
    "cv01": 2, // (1) plain, (2) slashed, (3) reverse slashed, (4) cut-out slash: 0
    "cv02": false, //  no serif: 1
    "cv10": true, // l i alternates (Neon, Argon, Xenon, Radon)
    "cv11": false, // j f r t alternates (Neon/Argon)
    "cv30": true, // top-aligned: *
    "cv31": true, // six-point: *
    "cv32": true, // angled: <= >=
    "cv62": true, // @_
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
    },
  },
  "unstable.ui_density": "comfortable",
  "restore_on_startup": "launchpad",
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
    "enabled": true,
  },
  "vim_mode": true,
  "vim": {
    "cursor_shape": {
      "normal": "block",
      "replace": "hollow",
    },
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "theme": { "dark": "Vercel Dark", "light": "Vercel Light", "mode": "system" },
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": false,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
    "show_background": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "terminal": {
    "dock": "right",
    "show_count_badge": true,
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": "Monaspace Krypton NF",
    "font_features": {
      "calt": true, // texture healing
      "liga": true, // // /// //// || ||| ||||
      "ss01": true, // != ===
      "ss02": true, // <= >=
      "ss03": true, // ~> ->
      "ss04": true, // </ /> </>
      "ss05": true, // |> <| <|>
      "ss06": true, // ## ++ __ == &&
      "ss07": true, // :: =:=
      "ss08": true, // ..= .-
      "ss09": true, // <=> >> =<<
      "ss10": true, // #[ ]# #( )#
      "cv01": 2, // (1) plain, (2) slashed, (3) reverse slashed, (4) cut-out slash: 0
      "cv02": false, //  no serif: 1
      "cv10": true, // l i alternates (Neon, Argon, Xenon, Radon)
      "cv11": false, // j f r t alternates (Neon/Argon)
      "cv30": true, // top-aligned: *
      "cv31": true, // six-point: *
      "cv32": true, // angled: <= >=
      "cv62": true, // @_
    },
    "font_size": 16,
    "env": {
      "EDITOR": "zed --wait",
    },
    "cursor_shape": "bar",
  },
  "scrollbar": {
    "show": "never",
  },
  "indent_guides": {
    "active_line_width": 3,
    "line_width": 2,
    "background_coloring": "disabled",
    "enabled": true,
    "coloring": "fixed",
  },
  "relative_line_numbers": "disabled",
  "wrap_guides": [100],
  "show_wrap_guides": false,
  "auto_install_extensions": {
    "basher": true,
    "cargo-appraiser": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "crates-lsp": true,
    "docker-compose": true,
    "dockerfile": true,
    "git-firefly": true,
    "github-classic": true,
    "github-theme": true,
    "golangci-lint": true,
    "gosum": true,
    "html": true,
    "just": true,
    "kotlin": true,
    "log": true,
    "make": true,
    "nord": true,
    "oxc": true,
    "package-swift-lsp": true,
    "prisma": true,
    "ruby": true,
    "svelte": true,
    "swift": true,
    "templ": true,
    "toml": true,
    "tsgo": true,
    "ultraviolet-theme": true,
    "vercel-theme": true,
    "vscode-icons": true,
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "update_debounce_ms": 100,
      "padding": 4,
      "min_column": 0,
      "enabled": true,
    },
    "button": true,
  },
  "languages": {
    "Prisma": {
      "prettier": {
        "allowed": false,
      },
    },
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "TSX": {
      "prettier": {
        "allowed": false,
      },
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } },
      ],
      "language_servers": ["tsgo", "!effect-tsgo", "oxlint", "oxfmt", "!vtsls"],
    },
    "TypeScript": {
      "prettier": {
        "allowed": false,
      },
      "format_on_save": "on",
      "formatter": [
        { "code_action": "source.fixAll.oxc" },
        { "language_server": { "name": "oxfmt" } },
      ],
      "language_servers": ["tsgo", "!effect-tsgo", "oxlint", "oxfmt", "!vtsls"],
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
        },
      },
    },
    "Svelte": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Go": {
      "format_on_save": "on",
      "language_servers": ["gopls", "golangci-lint"],
      "formatter": [
        "language_server",
        {
          "external": {
            "command": "golangci-lint",
            "arguments": ["fmt", "--stdin"],
          },
        },
      ],
    },
    "Templ": {
      "formatter": "language_server",
      "format_on_save": "on",
      "use_autoclose": false,
      "language_servers": ["templ", "tailwindcss-language-server"],
      "jsx_tag_auto_close": {
        "enabled": true,
      },
    },
    "Swift": {
      "hard_tabs": true,
    },
    "JSON": {
      "semantic_tokens": "off",
    },
    "JSONC": {
      "semantic_tokens": "off",
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 24576,
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 24576,
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "templ": "html",
        },
      },
    },
    "vscode-html-language-server": {
      "settings": {
        "html": {
          "suggest": {
            "html5": true,
            "angular1": true,
            "ionic": true,
          },
          "validate": {
            "scripts": true,
            "styles": true,
          },
          "format": {
            "wrapLineLength": 120,
            "unformatted": "wbr,code,pre",
          },
          "includeLanguages": {
            "templ": "html",
            "Templ": "html",
          },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
}
